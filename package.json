{
  "name": "cochrane-mcp",
  "version": "0.2.1",
  "description": "MCP server for searching the Cochrane Library — systematic reviews, trials (CENTRAL), clinical answers — and fetching structured review/trial details.",
  "type": "module",
  "license": "MIT",
  "author": "aliildan",
  "homepage": "https://github.com/aliildan/cochrane-mcp#readme",
  "repository": { "type": "git", "url": "git+https://github.com/aliildan/cochrane-mcp.git" },
  "bugs": { "url": "https://github.com/aliildan/cochrane-mcp/issues" },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cochrane",
    "systematic-review",
    "evidence-based-medicine",
    "medical",
    "healthcare",
    "research",
    "claude"
  ],
  "bin": { "cochrane-mcp": "dist/index.js" },
  "files": ["dist", "skills", "commands", ".claude-plugin", ".mcp.json", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "setup": "patchright install chromium",
    "postinstall": "patchright install chromium || true",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cheerio": "^1.0.0",
    "patchright": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": { "node": ">=18" }
}
